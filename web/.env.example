VITE_GEMINI_API_KEY=PASTE_YOUR_KEY_HERE

# İsteğe bağlı: Yönelim sonuç sayfasında Pusula özetinin yanında Groq ile ek öneri (kariyer analizinde kullandığın anahtarla aynı olabilir).
# VITE_GROQ_API_KEY=

# İsteğe bağlı: “Hangi alana yakınsın?” testi sonrası n8n’den JSON yanıtı.
# Workflow: Webhook → mantık → “Respond to Webhook” (body: { headline, subline, body, archetype, nextSteps }).
# Tarayıcıdan çağrıldığı için n8n / proxy CORS izni gerekebilir.
# VITE_N8N_ORIENTATION_WEBHOOK_URL=

# İsteğe bağlı: Ana sayfadaki "Güncel Staj Programları" listesi için n8n webhook (GET).
# Beklenen çıktı: dizi veya {items:[...]} (name/title, company, deadline, location, url, eligibility)
# VITE_N8N_INTERNSHIP_LIST_WEBHOOK_URL=

# Arkadaş daveti metnindeki link (üretimde ZORUNLU önerilir).
# Kullanma: tek deployment önizleme URL’si — bunlar genelde Vercel Authentication ile korunur ve “hesap aç”
# ekranına düşürür. Bunun yerine Vercel → Settings → Domains’te görünen Production domain’i yaz.
# Örnek (projedeki Domains → Production): https://pusula-app-two.vercel.app
# VITE_APP_SHARE_CANONICAL_URL=
