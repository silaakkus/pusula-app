# Örnek ortam dosyası — bunu commit edebilirsin; gerçek anahtarları BURAYA yazma.
# Gerçek değerler için web/.env oluştur (web/.env .gitignore ile GitHub’a gitmez).

# Sağlayıcı: gemini (varsayılan) veya groq
# VITE_LLM_PROVIDER=groq
# VITE_GROQ_API_KEY=gsk_...
# İsteğe bağlı: https://console.groq.com/docs/models
# VITE_GROQ_MODEL=llama-3.3-70b-versatile
# VITE_GROQ_TIMEOUT_MS=90000

VITE_GEMINI_API_KEY=PASTE_YOUR_KEY_HERE
# Paylaşım kartında kullanılacak kanonik site adresi (boşsa window.location.origin)
# VITE_APP_URL=https://your-production-domain.com

# Sonuç e-postası webhook (n8n vb.) — Zengin JSON: profile, rolesDetail (maaş/staj/LLM programları), opportunities (source)
# Aynı URL "Arkadaşını davet et" tıklamalarında da kullanılır: { event: "davet_tiklandi", kanal, zaman }
# İstersen olayları ayırmak için: VITE_PUSULA_EVENTS_WEBHOOK_URL=...
# Örnek Code node: repo kökünde n8n/pusula-webhook-code.js
# VITE_N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/...
# Varsayılan: gemini-1.5-flash-latest. Yedek zincirde gemini-pro YOK (v1beta’da 404).
# Ücretsiz API’de gemini-2.0-flash çoğu projede kota 0 verir; 1.5 ailesi kullanın.
# gemini-1.5-flash (suffixsiz) v1beta’da 404 — gemini-1.5-flash-latest kullanın.
# VITE_GEMINI_MODEL=gemini-1.5-pro-latest
# SDK varsayılanı v1beta; gerekirse v1 deneyin:
# VITE_GEMINI_API_VERSION=v1
# Tek bir generateContent çağrısı için ms (SDK’da timeout yoksa tarayıcı isteği süresiz bekleyebilir). Min 15000.
# VITE_GEMINI_TIMEOUT_MS=90000

